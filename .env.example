# ══════════════════════════════════════════════════════════
#  Campus AI Edge — Variables d'environnement
#  Copier ce fichier en .env et remplir les valeurs
# ══════════════════════════════════════════════════════════

# ─── Sécurité session (OBLIGATOIRE en production) ────────
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
APP_SESSION_SECRET=change_this_to_a_random_secret_key_64_chars

# ─── Modèle IA local (Ollama) ────────────────────────────
# Nom du modèle tel qu'il apparaît dans `ollama list`
CAMPUS_MODEL=gemma3:4b

# ─── Keycloak SSO (optionnel) ────────────────────────────
# Laisser vide pour désactiver Keycloak (mode sans auth SSO)
KEYCLOAK_SERVER_URL=http://localhost:8080
KEYCLOAK_REALM=ensa
KEYCLOAK_CLIENT_ID=elma-web
KEYCLOAK_CLIENT_SECRET=

# Rôles Keycloak (noms des rôles realm à créer dans Keycloak)
KEYCLOAK_ADMIN_ROLE=elma-admin
KEYCLOAK_DPO_ROLE=elma-dpo

# Scopes OIDC demandés
KEYCLOAK_SCOPES=openid profile email roles

# Redirection après déconnexion
KEYCLOAK_POST_LOGOUT_PATH=/

# ─── Contraintes email institutionnel ────────────────────
# Domaines autorisés séparés par des virgules (sans @)
# Exemple : usms.ac.ma,ensa.ac.ma
AUTH_ALLOWED_EMAIL_DOMAINS=usms.ac.ma,ensa.ac.ma

# Exiger que l'email soit vérifié dans Keycloak
AUTH_REQUIRE_VERIFIED_EMAIL=true
